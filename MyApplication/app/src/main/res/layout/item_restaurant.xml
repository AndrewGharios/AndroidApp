<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_date_card"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/restaurantNameText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold"
        tools:text="Ресторан &quot;Агидель&quot;" />

    <TextView
        android:id="@+id/restaurantAddressText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        tools:text="Уфа, ул. Ленина, 16" />

    <TextView
        android:id="@+id/restaurantDetailsText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        tools:text="8 столиков • Классический зал с широким центральным проходом." />

</LinearLayout>
